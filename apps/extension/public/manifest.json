{
  "manifest_version": 3,
  "name": "ChromeOS Input Assist",
  "version": "0.0.1",
  "description": "Input Assist — English autocorrect keyboard",
  "permissions": ["input", "storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "input_components": [
    {
      "name": "Input Assist",
      "type": "ime",
      "id": "input-assist",
      "description": "English autocorrect keyboard",
      "language": "en-US",
      "layouts": ["us::eng"]
    }
  ]
}
